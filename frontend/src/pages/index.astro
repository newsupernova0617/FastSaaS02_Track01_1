---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Screenshots from '../components/Screenshots.astro';
import HomeBlogPreview from '../components/HomeBlogPreview.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import Footer from '../components/Footer.astro';

const latestPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)
  .map((post) => ({
    slug: post.data.slug,
    title: post.data.title,
    description: post.data.description,
    excerpt: post.data.excerpt,
    category: post.data.category,
    publishDate: post.data.publishDate,
    readingTime: post.data.readingTime,
    tags: post.data.tags,
  }));

const featuredPost = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())[0];

const blogCategories = [
  {
    slug: 'money-basics',
    label: '돈 관리 기초',
    description: '가계부 시작, 예산, 항목 분류 같은 기본기',
  },
  {
    slug: 'life-stages',
    label: '상황별 가이드',
    description: '사회초년생, 자취생, 첫 월급 관리 같은 실전 주제',
  },
  {
    slug: 'app-guides',
    label: '앱 비교 가이드',
    description: '가계부 앱 비교, 개인정보, 자동 연동 체크포인트',
  },
];
---

<BaseLayout>
  <main>
    <Hero />
    <Features />
    <Screenshots />
    {latestPosts.length > 0 && (
      <HomeBlogPreview posts={latestPosts} featuredPost={featuredPost ? {
        slug: featuredPost.data.slug,
        title: featuredPost.data.title,
        description: featuredPost.data.description,
        excerpt: featuredPost.data.excerpt,
        category: featuredPost.data.category,
        publishDate: featuredPost.data.publishDate,
        readingTime: featuredPost.data.readingTime,
        tags: featuredPost.data.tags,
      } : undefined} categories={blogCategories} />
    )}
    <DownloadCTA />
  </main>
  <Footer />
</BaseLayout>
