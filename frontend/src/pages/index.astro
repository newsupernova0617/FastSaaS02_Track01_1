---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Screenshots from '../components/Screenshots.astro';
import HomeBlogPreview from '../components/HomeBlogPreview.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import Footer from '../components/Footer.astro';

const latestPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)
  .map((post) => ({
    slug: post.data.slug,
    title: post.data.title,
    description: post.data.description,
    excerpt: post.data.excerpt,
    category: post.data.category,
    publishDate: post.data.publishDate,
    readingTime: post.data.readingTime,
    tags: post.data.tags,
  }));
---

<BaseLayout>
  <main>
    <Hero />
    <Features />
    <Screenshots />
    {latestPosts.length > 0 && <HomeBlogPreview posts={latestPosts} />}
    <DownloadCTA />
  </main>
  <Footer />
</BaseLayout>
