---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCta from '../../components/BlogPostCta.astro';
import Footer from '../../components/Footer.astro';

const categoryLabels = {
  'money-basics': '돈 관리 기초',
  'life-stages': '상황별 가이드',
  'saving-tips': '절약 실전',
  'app-guides': '앱 사용 가이드',
} as const;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const relatedPosts = (await getCollection('blog'))
  .filter(
    (item) =>
      !item.data.draft &&
      item.id !== post.id &&
      (item.data.category === post.data.category ||
        item.data.tags.some((tag: string) => post.data.tags.includes(tag))),
  )
  .slice(0, 3);
const origin = Astro.site?.toString() ?? 'https://fastsaas.pages.dev';
const canonical = new URL(`/blog/${post.data.slug}/`, origin).toString();
const publishedTime = post.data.publishDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.publishDate).toISOString();
const ogImage = post.data.ogImage ?? `/blog/og/${post.data.slug}.svg`;
---

<BaseLayout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.seoDescription ?? post.data.description}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  articleTags={post.data.tags}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: publishedTime,
    dateModified: modifiedTime,
    author: {
      '@type': 'Organization',
      name: 'FastSaaS',
    },
    publisher: {
      '@type': 'Organization',
      name: 'FastSaaS',
      url: origin,
    },
    mainEntityOfPage: canonical,
    image: new URL(ogImage, origin).toString(),
    keywords: post.data.tags.join(', '),
  }}
>
  <main class="bg-[linear-gradient(to_bottom,_#ffffff,_#f7f7f8)]">
    <article class="mx-auto max-w-4xl px-6 pb-24 pt-20">
      <header class="reveal rounded-[32px] border border-base-300 bg-white p-8 shadow-sm sm:p-10">
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-base-content/50">
          <span class="rounded-full bg-primary/10 px-3 py-1 text-primary">
            {categoryLabels[post.data.category]}
          </span>
          <span>{post.data.publishDate.toLocaleDateString('ko-KR')}</span>
          <span>{post.data.readingTime ?? 5}분 읽기</span>
        </div>
        <h1 class="mt-5 text-4xl font-black leading-tight text-base-content sm:text-5xl">
          {post.data.title}
        </h1>
        <p class="mt-5 text-lg leading-8 text-base-content/72">{post.data.description}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full bg-base-200 px-3 py-1 text-xs font-medium text-base-content/65">
              #{tag}
            </span>
          ))}
        </div>
      </header>

      <div class="mt-10 rounded-[32px] border border-base-300 bg-white px-6 py-10 shadow-sm sm:px-10">
        <div class="blog-prose prose prose-lg max-w-none prose-headings:font-black prose-headings:text-base-content prose-p:text-base-content/80 prose-li:text-base-content/80 prose-strong:text-base-content">
          <Content />
        </div>
      </div>

      <div class="mt-10">
        <BlogPostCta />
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 pb-24">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="text-2xl font-extrabold text-base-content">같이 보면 좋은 글</h2>
          <a href="/blog/" class="text-sm font-semibold text-primary hover:underline">블로그 전체 보기</a>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {relatedPosts.map((item) => (
            <a
              href={`/blog/${item.data.slug}/`}
              data-track-event="blog_related_click"
              data-track-source="blog_detail"
              data-track-slug={item.data.slug}
              class="rounded-[24px] border border-base-300 bg-white p-6 transition hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg"
            >
              <div class="text-xs font-semibold text-base-content/45">
                {categoryLabels[item.data.category]}
              </div>
              <h3 class="mt-3 text-lg font-extrabold leading-snug text-base-content">
                {item.data.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-base-content/70">{item.data.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-prose :global(h2) {
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    font-size: 1.875rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: rgb(17 24 39);
  }

  .blog-prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.025em;
    color: rgb(17 24 39);
  }

  .blog-prose :global(p) {
    margin-top: 1rem;
    margin-bottom: 1rem;
    font-size: 1.0625rem;
    line-height: 1.9;
  }

  .blog-prose :global(hr) {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid rgb(226 232 240);
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    margin-top: 1rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-prose :global(ul) {
    list-style: disc;
  }

  .blog-prose :global(ol) {
    list-style: decimal;
  }

  .blog-prose :global(li) {
    margin-top: 0.45rem;
    line-height: 1.8;
  }

  .blog-prose :global(li)::marker {
    color: rgb(71 85 105);
    font-weight: 700;
  }

  .blog-prose :global(blockquote) {
    margin: 1.75rem 0;
    border-left: 4px solid rgb(37 99 235);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(248, 250, 252, 0.9));
    padding: 1rem 1.25rem;
    color: rgb(51 65 85);
    font-size: 1.02rem;
    font-weight: 500;
    line-height: 1.85;
  }

  .blog-prose :global(blockquote p:first-child) {
    margin-top: 0;
  }

  .blog-prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .blog-prose :global(a) {
    font-weight: 700;
    color: rgb(37 99 235);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .blog-prose :global(strong) {
    font-weight: 800;
    color: rgb(17 24 39);
  }

  .blog-prose :global(code) {
    border-radius: 0.5rem;
    background: rgb(243 244 246);
    padding: 0.15rem 0.4rem;
    font-size: 0.95em;
    color: rgb(30 41 59);
  }

  .blog-prose :global(pre) {
    margin: 1.5rem 0;
    overflow-x: auto;
    border-radius: 1rem;
    background: rgb(15 23 42);
    padding: 1rem 1.125rem;
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.12);
  }

  .blog-prose :global(pre code) {
    display: block;
    background: transparent;
    padding: 0;
    color: rgb(226 232 240);
    font-size: 0.95rem;
    line-height: 1.7;
    white-space: pre;
  }

  .blog-prose :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.75rem 0;
    border-radius: 1rem;
    box-shadow: inset 0 0 0 1px rgb(229 231 235);
  }

  .blog-prose :global(thead) {
    background: rgb(248 250 252);
  }

  .blog-prose :global(th),
  .blog-prose :global(td) {
    min-width: 9rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.7;
  }

  .blog-prose :global(th) {
    font-size: 0.95rem;
    font-weight: 800;
    color: rgb(17 24 39);
  }

  .blog-prose :global(td) {
    font-size: 0.98rem;
    color: rgb(51 65 85);
  }

  .blog-prose :global(tr:last-child td) {
    border-bottom: 0;
  }

  .blog-prose :global(img) {
    margin: 1.75rem 0;
    width: 100%;
    border-radius: 1.25rem;
    border: 1px solid rgb(229 231 235);
    box-shadow: 0 18px 40px -24px rgba(15, 23, 42, 0.28);
  }

  .blog-prose :global(figure) {
    margin: 2rem 0;
  }

  .blog-prose :global(figcaption) {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.9rem;
    color: rgb(100 116 139);
  }

  @media (max-width: 640px) {
    .blog-prose :global(h2) {
      font-size: 1.55rem;
    }

    .blog-prose :global(h3) {
      font-size: 1.2rem;
    }

    .blog-prose :global(p) {
      font-size: 1rem;
      line-height: 1.8;
    }
  }
</style>
