---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCta from '../../components/BlogPostCta.astro';
import Footer from '../../components/Footer.astro';

const categoryLabels = {
  'money-basics': '돈 관리 기초',
  'life-stages': '상황별 가이드',
  'saving-tips': '절약 실전',
  'app-guides': '앱 사용 가이드',
} as const;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const relatedPosts = (await getCollection('blog'))
  .filter(
    (item) =>
      !item.data.draft &&
      item.id !== post.id &&
      (item.data.category === post.data.category ||
        item.data.tags.some((tag: string) => post.data.tags.includes(tag))),
  )
  .slice(0, 3);
const origin = Astro.site?.toString() ?? 'https://fastsaas.pages.dev';
const canonical = new URL(`/blog/${post.data.slug}/`, origin).toString();
const publishedTime = post.data.publishDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.publishDate).toISOString();
const ogImage = post.data.ogImage ?? `/blog/og/${post.data.slug}.svg`;
---

<BaseLayout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.seoDescription ?? post.data.description}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  articleTags={post.data.tags}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: publishedTime,
    dateModified: modifiedTime,
    author: {
      '@type': 'Organization',
      name: 'FastSaaS',
    },
    publisher: {
      '@type': 'Organization',
      name: 'FastSaaS',
      url: origin,
    },
    mainEntityOfPage: canonical,
    image: new URL(ogImage, origin).toString(),
    keywords: post.data.tags.join(', '),
  }}
>
  <main class="bg-[linear-gradient(to_bottom,_#ffffff,_#f8f8f9)]">
    <article class="mx-auto max-w-6xl px-6 pb-24 pt-20">
      <div class="mb-8 reveal">
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 rounded-full border border-slate-200/90 bg-white px-4 py-2 text-sm font-semibold text-base-content/72 transition hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary"
        >
          <span aria-hidden="true">←</span>
          블로그 홈
        </a>
      </div>
      <header class="reveal overflow-hidden rounded-[22px] border border-slate-200/90 bg-white">
        <div class="border-b border-slate-200/90 px-8 py-7 sm:px-10 sm:py-8">
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-base-content/50">
            <span class="rounded-full border border-primary/15 bg-primary/8 px-3 py-1 text-primary">
              {categoryLabels[post.data.category]}
            </span>
            <span>{post.data.publishDate.toLocaleDateString('ko-KR')}</span>
            <span>{post.data.readingTime ?? 5}분 읽기</span>
          </div>
          <h1 class="mt-5 max-w-4xl text-4xl font-black leading-[1.08] tracking-tight text-base-content sm:text-5xl">
            {post.data.title}
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-base-content/70">{post.data.description}</p>
        </div>

        <div class="px-8 py-5 sm:px-10 sm:py-6">
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full border border-slate-200/90 bg-slate-50/85 px-3 py-1 text-xs font-medium text-base-content/62">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <div class="mt-10 grid gap-6 xl:grid-cols-[minmax(0,1fr)_260px] xl:items-start">
        <div class="rounded-[22px] border border-slate-200/90 bg-white px-6 py-10 sm:px-10">
          {tocItems.length >= 3 && (
            <nav
              aria-label="Table of contents"
              class="toc-panel mb-10 xl:hidden"
            >
              <div class="flex items-center justify-between gap-4">
                <div>
                  <div class="text-[0.7rem] font-black uppercase tracking-[0.2em] text-primary/70">
                    Navigate
                  </div>
                  <div class="mt-1 text-lg font-black text-base-content">On This Page</div>
                </div>
                <div class="rounded-full border border-slate-200/90 bg-white px-3 py-1 text-xs font-semibold text-base-content/55">
                  {tocItems.length} sections
                </div>
              </div>
              <ol class="toc-list mt-5 space-y-2.5">
                {tocItems.map((heading, index) => (
                  <li class:list={[heading.depth === 3 && 'toc-subitem']}>
                    <a
                      href={`#${heading.slug}`}
                      data-track-event="blog_toc_click"
                      data-track-source="blog_detail_mobile"
                      data-track-slug={post.data.slug}
                      data-track-heading={heading.slug}
                      class:list={[
                        'toc-link',
                        heading.depth === 3 && 'toc-link-subtle',
                      ]}
                    >
                      <span class="toc-index">{String(index + 1).padStart(2, '0')}</span>
                      <span>{heading.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )}
          <div class="blog-prose prose prose-slate prose-lg max-w-none prose-headings:font-black prose-headings:tracking-normal prose-headings:text-base-content prose-p:text-base-content/80 prose-p:leading-8 prose-li:text-base-content/78 prose-li:leading-8 prose-strong:text-base-content prose-a:text-primary prose-a:font-bold prose-a:decoration-slate-300 prose-a:underline-offset-4 hover:prose-a:text-accent hover:prose-a:decoration-primary prose-code:rounded-md prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-[0.95em] prose-code:font-semibold prose-code:text-slate-800 prose-pre:rounded-[20px] prose-pre:bg-slate-950 prose-blockquote:rounded-r-[18px] prose-blockquote:border-l-4 prose-blockquote:border-primary/25 prose-blockquote:bg-blue-50/55 prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:font-medium prose-blockquote:text-slate-700 prose-hr:border-base-300 prose-img:rounded-[20px] prose-img:border prose-img:border-base-300 prose-th:text-base-content prose-th:font-extrabold prose-td:text-base-content/76 prose-td:align-top prose-headings:scroll-mt-28">
            <Content />
          </div>
        </div>

        {tocItems.length >= 3 && (
          <aside class="hidden xl:block">
            <nav aria-label="Table of contents" class="toc-panel toc-panel-sticky">
              <div class="text-[0.7rem] font-black uppercase tracking-[0.2em] text-primary/70">
                Reading Guide
              </div>
              <div class="mt-2 text-xl font-black leading-tight text-base-content">On This Page</div>
              <p class="mt-2 text-sm leading-6 text-base-content/58">
                지금 읽는 글의 핵심 섹션을 바로 이동할 수 있습니다.
              </p>
              <ol class="toc-list mt-6 space-y-2">
                {tocItems.map((heading, index) => (
                  <li class:list={[heading.depth === 3 && 'toc-subitem']}>
                    <a
                      href={`#${heading.slug}`}
                      data-track-event="blog_toc_click"
                      data-track-source="blog_detail_desktop"
                      data-track-slug={post.data.slug}
                      data-track-heading={heading.slug}
                      class:list={[
                        'toc-link',
                        heading.depth === 3 && 'toc-link-subtle',
                      ]}
                    >
                      <span class="toc-index">{String(index + 1).padStart(2, '0')}</span>
                      <span>{heading.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )}
      </div>

      <div class="mt-10">
        <BlogPostCta />
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 pb-24">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="text-[0.72rem] font-black uppercase tracking-[0.18em] text-primary/70">Keep Reading</p>
            <h2 class="mt-2 text-2xl font-extrabold text-base-content">다음으로 읽기 좋은 글</h2>
          </div>
          <a href="/blog/" class="text-sm font-semibold text-primary hover:underline">블로그 전체 보기</a>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {relatedPosts.map((item) => (
            <a
              href={`/blog/${item.data.slug}/`}
              data-track-event="blog_related_click"
              data-track-source="blog_detail"
              data-track-slug={item.data.slug}
              class="group grid content-start rounded-[18px] border border-slate-200/90 bg-white p-5 transition hover:-translate-y-0.5 hover:border-slate-300"
            >
              <div class="flex items-center justify-between gap-3 text-xs font-semibold text-base-content/45">
                <span>{categoryLabels[item.data.category]}</span>
                <span>{item.data.readingTime ?? 5}분</span>
              </div>
              <h3 class="mt-3 text-lg font-extrabold leading-snug text-base-content transition group-hover:text-primary">
                {item.data.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-base-content/68">{item.data.excerpt}</p>
              <div class="mt-4 text-xs font-semibold uppercase tracking-[0.14em] text-base-content/35">
                다음 글
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .toc-panel {
    border: 1px solid rgb(226 232 240 / 0.9);
    border-radius: 1.125rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.94));
    padding: 1.1rem;
  }

  .toc-panel-sticky {
    position: sticky;
    top: 6rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-subitem {
    padding-left: 1rem;
  }

  .toc-link {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    align-items: start;
    gap: 0.7rem;
    border-radius: 0.8rem;
    padding: 0.62rem 0.72rem;
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.55;
    color: rgb(51 65 85);
    text-decoration: none;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .toc-link:hover {
    transform: translateX(2px);
    background: rgba(255, 255, 255, 0.92);
    color: rgb(37 99 235);
  }

  .toc-link-subtle {
    color: rgb(71 85 105);
    font-weight: 600;
  }

  .toc-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.75rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.06);
    color: rgb(37 99 235 / 0.85);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .blog-prose :global(li)::marker {
    color: rgb(71 85 105);
    font-weight: 700;
  }

  .blog-prose :global(> p:first-of-type) {
    margin-top: 0;
    font-size: 1.12rem;
    line-height: 1.9;
    color: rgb(30 41 59);
  }

  .blog-prose :global(h2) {
    margin-top: 3rem;
    margin-bottom: 0.9rem;
  }

  .blog-prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.65rem;
  }

  .blog-prose :global(h2 + p),
  .blog-prose :global(h3 + p) {
    margin-top: 0.6rem;
  }

  .blog-prose :global(blockquote p:first-child) {
    margin-top: 0;
  }

  .blog-prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .blog-prose :global(pre code) {
    display: block;
    background: transparent !important;
    padding: 0;
    color: rgb(226 232 240);
    font-size: 0.95rem;
    line-height: 1.7;
    white-space: pre;
  }

  .blog-prose :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    margin: 2rem 0;
    border-collapse: collapse;
    border-radius: 1rem;
    border: 1px solid rgb(229 231 235);
  }

  .blog-prose :global(thead) {
    background: rgb(248 250 252 / 0.9);
  }

  .blog-prose :global(th),
  .blog-prose :global(td) {
    min-width: 9rem;
    border-bottom: 1px solid rgb(229 231 235);
    padding: 0.85rem 1rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.7;
  }

  .blog-prose :global(tr:last-child td) {
    border-bottom: 0;
  }

  .blog-prose :global(figure) {
    margin: 2rem 0;
  }

  .blog-prose :global(figcaption) {
    margin-top: 0.85rem;
    text-align: center;
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgb(100 116 139);
  }

  @media (max-width: 640px) {
    .toc-panel {
      padding: 1rem;
    }

    .toc-link {
      grid-template-columns: 2rem minmax(0, 1fr);
      gap: 0.65rem;
      padding: 0.65rem 0.7rem;
      font-size: 0.88rem;
    }

    .blog-prose {
      font-size: 1rem;
    }

    .blog-prose :global(> p:first-of-type) {
      font-size: 1.06rem;
      line-height: 1.85;
    }
  }
</style>
