---
import { site, downloadCopy } from '../content';
import StoreBadge from './StoreBadge.astro';
import ChatDemo from './ChatDemo.astro';
---

<section class="relative overflow-hidden bg-base-100">
  <!-- 배경: 미묘한 그리드 + 블러 오브 -->
  <div class="absolute inset-0 -z-10 opacity-60" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(17,19,24,0.06) 1px, transparent 0); background-size: 28px 28px;"></div>
    <div class="absolute top-20 -left-40 h-96 w-96 rounded-full bg-primary/15 blur-3xl"></div>
    <div class="absolute top-40 right-0 h-80 w-80 rounded-full bg-secondary/10 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 pt-20 pb-16 sm:pt-28 sm:pb-24 lg:pt-32">
    <div class="grid items-center gap-16 lg:grid-cols-[1.1fr_1fr] lg:gap-12">
      <!-- 좌측: 헤드라인 + CTA -->
      <div class="reveal">
        <div class="flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center gap-2 rounded-full border border-base-300 bg-base-100 px-3.5 py-1.5 text-xs font-semibold text-base-content/70">
            <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
            정식 출시 준비 중 · {site.brand}
          </span>
          <a
            href="/blog"
            data-track-event="home_blog_top_click"
            data-track-source="hero_top"
            class="inline-flex items-center gap-2 rounded-full border border-base-300 bg-white/92 px-3.5 py-1.5 text-xs font-semibold text-base-content/72 transition hover:-translate-y-0.5 hover:border-primary/30 hover:text-primary"
          >
            블로그 바로가기
          </a>
        </div>

        <h1 class="mt-6 text-[2.5rem] font-black leading-[1.1] tracking-tight text-base-content sm:text-5xl lg:text-[4rem]">
          말로 하는<br />
          <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">
            가장 쉬운 가계부.
          </span>
        </h1>

        <p class="mt-5 max-w-xl text-lg text-base-content/65 sm:text-xl">
          {site.subTagline}
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a
            href="#waitlist"
            data-track-event="home_waitlist_click"
            data-track-source="hero"
            class="app-btn app-btn-primary px-7 py-4 text-base"
          >
            출시 알림 받기
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="#features"
            data-track-event="home_features_click"
            data-track-source="hero"
            class="app-btn border border-slate-200 bg-slate-50/92 px-7 py-4 text-base font-semibold text-slate-700 shadow-sm hover:border-slate-300 hover:bg-white hover:text-slate-950"
          >
            기능 자세히 보기
          </a>
          <a
            href="/blog"
            data-track-event="home_blog_click"
            data-track-source="hero"
            class="app-btn app-btn-outline px-7 py-4 text-base"
          >
            블로그 보기
          </a>
        </div>

        <!-- 스토어 뱃지 (보조 CTA) -->
        <div class="mt-10 flex flex-col gap-3 border-t border-base-300 pt-6 sm:flex-row sm:items-center">
          <p class="text-sm font-medium text-base-content/50">곧 만나보실 수 있어요</p>
          <div class="flex gap-2.5">
            <StoreBadge platform="android" disabled />
            <StoreBadge platform="ios" disabled />
          </div>
        </div>
      </div>

      <!-- 우측: 채팅 데모 목업 -->
      <div class="relative reveal" style="animation-delay: 0.3s">
        <ChatDemo />
      </div>
    </div>
  </div>
</section>
