---
import { ScanSearch } from 'lucide-react';

interface Props {
  title?: string;
}

const { title = '핵심 요약' } = Astro.props;
---

<section class="not-prose mdx-summary my-9 overflow-hidden rounded-[18px] border border-slate-200/90 bg-white">
  <div class="border-b border-slate-200/90 px-5 py-4 sm:px-6">
    <div class="flex items-center gap-3">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-primary">
        <ScanSearch size={16} strokeWidth={2.2} />
      </span>
      <p class="text-[0.78rem] font-black uppercase tracking-[0.16em] text-slate-500">Summary</p>
    </div>
    <h3 class="mt-2 text-xl font-black leading-tight text-slate-950">{title}</h3>
  </div>
  <div class="grid gap-0 divide-y divide-slate-200/90 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <slot />
  </div>
</section>
