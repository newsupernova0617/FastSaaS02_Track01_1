---
interface Props {
  title?: string;
}

const { title = '핵심 요약' } = Astro.props;
---

<section class="mdx-summary my-9 overflow-hidden rounded-[22px] border border-slate-200 bg-white shadow-[0_18px_45px_-34px_rgba(15,23,42,0.55)]">
  <div class="border-b border-slate-200 bg-[linear-gradient(135deg,_rgba(15,23,42,0.04),_rgba(37,99,235,0.08),_rgba(255,255,255,0.95))] px-5 py-4 sm:px-6">
    <div class="flex items-center gap-3">
      <span class="h-2.5 w-2.5 rounded-full bg-primary shadow-[0_0_0_5px_rgba(37,99,235,0.12)]"></span>
      <p class="text-[0.78rem] font-black uppercase tracking-[0.16em] text-slate-500">
        Summary
      </p>
    </div>
    <h3 class="mt-2 text-xl font-black leading-tight text-slate-950">{title}</h3>
  </div>
  <div class="grid gap-0 divide-y divide-slate-200 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <slot />
  </div>
</section>
