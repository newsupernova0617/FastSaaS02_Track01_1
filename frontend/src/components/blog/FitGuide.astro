---
interface Props {
  title?: string;
  fit: string[];
  notFit?: string[];
}

const {
  title = '이런 분께 맞습니다',
  fit,
  notFit = [],
} = Astro.props;
---

<section class="my-8 rounded-[28px] border border-slate-200 bg-[linear-gradient(135deg,_rgba(15,23,42,0.02),_rgba(255,255,255,0.98))] px-5 py-6 shadow-sm sm:px-7">
  <div class="grid gap-5 md:grid-cols-[1.15fr_0.85fr]">
    <div>
      <h3 class="text-xl font-black tracking-tight text-slate-900">{title}</h3>
      <ul class="mt-4 space-y-3">
        {fit.map((item) => (
          <li class="flex gap-3 text-[1rem] leading-7 text-slate-700">
            <span class="mt-1 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-primary/10 text-[0.75rem] font-black text-primary">
              ✓
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    {notFit.length > 0 && (
      <div class="rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4">
        <div class="text-sm font-extrabold uppercase tracking-[0.18em] text-slate-500">
          이런 경우는 다른 방식이 나을 수 있습니다
        </div>
        <ul class="mt-3 space-y-2">
          {notFit.map((item) => (
            <li class="text-[0.95rem] leading-7 text-slate-600">{item}</li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>
