---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  features: string[];
  imageSrc?: string;
  imageAlt?: string;
  imagePlaceholder?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  eyebrow = '앱에서 직접 해보면',
  title,
  description,
  features,
  imageSrc,
  imageAlt = '',
  imagePlaceholder = '스크린샷 준비 중',
  ctaText = '무료로 시작하기',
  ctaHref = '/',
} = Astro.props;
---

<section class="not-prose my-10 overflow-hidden rounded-[20px] border border-slate-200/90 bg-white">
  <div class="grid md:grid-cols-[1fr_1.1fr]">
    <div class="flex items-center justify-center bg-slate-50/80 p-6 md:p-8">
      {imageSrc ? (
        <img
          src={imageSrc}
          alt={imageAlt}
          class="w-full max-w-[260px] rounded-[16px] shadow-[0_12px_40px_-16px_rgba(15,23,42,0.3)]"
        />
      ) : (
        <div class="flex h-[300px] w-full max-w-[240px] flex-col items-center justify-center gap-3 rounded-[16px] border-2 border-dashed border-slate-300 bg-white text-center px-4">
          <span class="text-3xl">📱</span>
          <span class="text-[0.78rem] font-semibold leading-snug text-slate-400">{imagePlaceholder}</span>
        </div>
      )}
    </div>

    <div class="flex flex-col justify-center px-6 py-7 sm:px-8">
      <p class="text-[0.7rem] font-black uppercase tracking-[0.2em] text-primary/80">{eyebrow}</p>
      <h3 class="mt-2 text-xl font-black leading-tight tracking-tight text-slate-950">{title}</h3>
      <p class="mt-3 text-[0.95rem] leading-7 text-slate-600">{description}</p>

      <ul class="mt-5 space-y-2.5">
        {features.map((feature) => (
          <li class="flex items-start gap-2.5 text-[0.95rem] leading-7 text-slate-700">
            <span class="mt-[0.45rem] inline-flex h-4 w-4 flex-none items-center justify-center rounded-full bg-primary/10 text-[0.6rem] font-black text-primary">✓</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>

      <a
        href={ctaHref}
        class="mt-7 inline-flex w-fit items-center gap-2 rounded-full bg-slate-950 px-5 py-2.5 text-[0.85rem] font-bold text-white transition-opacity hover:opacity-80"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
