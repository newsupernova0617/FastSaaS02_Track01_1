---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: Item[];
}

const { title = '자주 묻는 질문', items } = Astro.props;
---

<section class="my-8 rounded-[28px] border border-slate-200 bg-white px-5 py-6 shadow-sm sm:px-7">
  <div class="mb-5 flex items-center gap-3">
    <span class="inline-flex rounded-full bg-slate-900 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.18em] text-white">
      FAQ
    </span>
    <h3 class="text-xl font-black tracking-tight text-slate-900">{title}</h3>
  </div>
  <div class="space-y-3">
    {items.map((item) => (
      <details class="group rounded-[20px] border border-slate-200 bg-slate-50/85 px-4 py-4">
        <summary class="cursor-pointer list-none pr-8 text-[1rem] font-extrabold leading-7 text-slate-900 marker:content-none">
          {item.question}
          <span class="float-right text-slate-400 transition group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-[0.98rem] leading-7 text-slate-700">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
