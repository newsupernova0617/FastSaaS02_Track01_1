---
import { CircleHelp, Plus } from 'lucide-react';

interface Item {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: Item[];
}

const { title = '자주 묻는 질문', items } = Astro.props;
---

<section class="not-prose my-9 rounded-[18px] border border-slate-200/90 bg-white p-5 sm:p-6">
  <div class="mb-5 flex items-end justify-between gap-4">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-50 text-primary ring-1 ring-slate-200">
        <CircleHelp size={18} strokeWidth={2.1} />
      </span>
      <div>
      <p class="text-[0.72rem] font-black uppercase tracking-[0.18em] text-primary/75">❓ FAQ</p>
      <h3 class="mt-2 text-xl font-black tracking-tight text-slate-950">{title}</h3>
      </div>
    </div>
    <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-bold text-slate-500">
      {items.length} answers
    </span>
  </div>
  <div class="space-y-3">
    {items.map((item) => (
      <details class="group rounded-[14px] border border-slate-200/90 bg-slate-50/70 px-4 py-4 transition open:bg-white">
        <summary class="grid cursor-pointer list-none grid-cols-[minmax(0,1fr)_1.75rem] items-start gap-3 text-[1rem] font-extrabold leading-7 text-slate-950 marker:content-none">
          <span>{item.question}</span>
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-white text-sm font-black text-slate-400 ring-1 ring-slate-200 transition group-open:rotate-45 group-open:text-primary">
            <Plus size={15} strokeWidth={2.4} />
          </span>
        </summary>
        <p class="mt-3 border-t border-slate-200/90 pt-3 text-[0.98rem] leading-8 text-slate-700">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
