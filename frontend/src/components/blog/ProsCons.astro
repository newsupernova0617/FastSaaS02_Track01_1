---
interface Item {
  title: string;
  items: string[];
}

interface Props {
  prosTitle?: string;
  consTitle?: string;
  pros: string[];
  cons: string[];
}

const {
  prosTitle = '장점',
  consTitle = '주의할 점',
  pros,
  cons,
} = Astro.props;

const sections: Item[] = [
  { title: prosTitle, items: pros },
  { title: consTitle, items: cons },
];
---

<section class="my-8 grid gap-4 md:grid-cols-2">
  {sections.map((section, index) => (
    <div
      class:list={[
        'rounded-[24px] border px-5 py-5 shadow-sm sm:px-6',
        index === 0
          ? 'border-emerald-200 bg-emerald-50/80'
          : 'border-amber-200 bg-amber-50/90',
      ]}
    >
      <h3 class="text-xl font-black tracking-tight text-slate-900">{section.title}</h3>
      <ul class="mt-4 space-y-3">
        {section.items.map((item) => (
          <li class="flex gap-3 text-[1rem] leading-7 text-slate-700">
            <span
              class:list={[
                'mt-1 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full text-[0.75rem] font-black',
                index === 0
                  ? 'bg-emerald-100 text-emerald-700'
                  : 'bg-amber-100 text-amber-700',
              ]}
            >
              {index === 0 ? '+' : '!'}
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>
