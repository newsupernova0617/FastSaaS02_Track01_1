---
interface Item {
  title: string;
  items: string[];
}

interface Props {
  prosTitle?: string;
  consTitle?: string;
  pros: string[];
  cons: string[];
}

const {
  prosTitle = '장점',
  consTitle = '주의할 점',
  pros,
  cons,
} = Astro.props;

const sections: Item[] = [
  { title: prosTitle, items: pros },
  { title: consTitle, items: cons },
];
---

<section class="not-prose my-9 grid overflow-hidden rounded-[18px] border border-slate-200/90 bg-white md:grid-cols-2">
  {sections.map((section, index) => (
    <div
      class:list={[
        'px-5 py-5 sm:px-6',
        index === 0 ? 'bg-emerald-50/70' : 'bg-amber-50/80 md:border-l md:border-slate-200/90',
      ]}
    >
      <div class="flex items-center gap-3">
        <span
          class:list={[
            'inline-flex h-8 w-8 items-center justify-center rounded-full text-sm font-black ring-1',
            index === 0
              ? 'bg-white text-emerald-700 ring-emerald-200'
              : 'bg-white text-amber-700 ring-amber-200',
          ]}
        >
          {index === 0 ? '+' : '!'}
        </span>
        <h3 class="text-xl font-black tracking-tight text-slate-950">{section.title}</h3>
      </div>
      <ul class="mt-5 space-y-3">
        {section.items.map((item) => (
          <li class="grid grid-cols-[0.55rem_minmax(0,1fr)] gap-3 text-[1rem] leading-7 text-slate-700">
            <span
              class:list={[
                'mt-3 h-1.5 w-1.5 rounded-full',
                index === 0 ? 'bg-emerald-600' : 'bg-amber-500',
              ]}
            ></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>
