---
interface Item {
  text: string;
}

interface Props {
  title?: string;
  items: Item[] | string[];
}

const { title = '체크리스트', items } = Astro.props;
const normalizedItems = items.map((item) => (typeof item === 'string' ? item : item.text));
---

<section class="not-prose my-9 overflow-hidden rounded-[18px] border border-slate-200/90 bg-white">
  <div class="flex items-center justify-between gap-4 border-b border-slate-200/90 bg-slate-50 px-5 py-4 sm:px-6">
    <div>
      <p class="text-[0.72rem] font-black uppercase tracking-[0.18em] text-slate-500">Action List</p>
      <h3 class="mt-1 text-xl font-black leading-tight text-slate-950">{title}</h3>
    </div>
    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-bold text-slate-500">
      {normalizedItems.length} items
    </span>
  </div>
  <ol class="divide-y divide-slate-200/90">
    {normalizedItems.map((item, index) => (
      <li class="grid grid-cols-[2.35rem_minmax(0,1fr)] gap-3 px-5 py-4 text-[1rem] leading-7 text-slate-700 sm:px-6">
        <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full bg-emerald-50 text-xs font-black text-emerald-700 ring-1 ring-emerald-100">
          {index + 1}
        </span>
        <span>{item}</span>
      </li>
    ))}
  </ol>
</section>
