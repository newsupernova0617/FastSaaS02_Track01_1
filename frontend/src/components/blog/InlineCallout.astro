---
import { AlertTriangle, Lightbulb, ScanSearch } from 'lucide-react';

interface Props {
  label?: string;
  tone?: 'note' | 'tip' | 'warning';
}

const { label = '핵심', tone = 'note' } = Astro.props;

const toneMap = {
  note: {
    wrapper: 'border-primary/20 bg-primary/[0.08]',
    accent: 'bg-primary',
    label: 'text-primary',
    iconWrap: 'bg-white text-primary ring-1 ring-primary/12',
    Icon: ScanSearch,
  },
  tip: {
    wrapper: 'border-emerald-200 bg-emerald-50/90',
    accent: 'bg-emerald-500',
    label: 'text-emerald-700',
    iconWrap: 'bg-white text-emerald-700 ring-1 ring-emerald-200',
    Icon: Lightbulb,
  },
  warning: {
    wrapper: 'border-amber-200 bg-amber-50/90',
    accent: 'bg-amber-500',
    label: 'text-amber-700',
    iconWrap: 'bg-white text-amber-700 ring-1 ring-amber-200',
    Icon: AlertTriangle,
  },
} as const;

const styles = toneMap[tone];
const Icon = styles.Icon;
---

<aside class={`not-prose my-7 overflow-hidden rounded-[18px] border shadow-[0_10px_28px_-20px_rgba(15,23,42,0.35)] ${styles.wrapper}`}>
  <div class={`h-1.5 w-full ${styles.accent}`}></div>
  <div class="grid grid-cols-[2.5rem_minmax(0,1fr)] gap-3 px-4 py-4 sm:px-5">
    <span class={`mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full shadow-sm ${styles.iconWrap}`}>
      <Icon size={17} strokeWidth={2.2} />
    </span>
    <div class="min-w-0">
      <div class={`text-[0.7rem] font-black uppercase tracking-[0.2em] ${styles.label}`}>{label}</div>
      <div class="mt-1.5 text-[0.98rem] leading-7 text-slate-800">
        <slot />
      </div>
    </div>
  </div>
</aside>
