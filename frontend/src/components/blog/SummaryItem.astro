---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="rounded-[20px] border border-white/70 bg-white/90 px-4 py-4 shadow-sm">
  <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-slate-500">{label}</p>
  <div class="mt-2 text-[1rem] leading-7 text-slate-700">
    <slot />
  </div>
</div>
