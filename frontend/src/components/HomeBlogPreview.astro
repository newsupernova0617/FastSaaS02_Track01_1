---
interface PostPreview {
  slug: string;
  title: string;
  description: string;
  excerpt: string;
  category: 'money-basics' | 'life-stages' | 'saving-tips' | 'app-guides';
  publishDate: Date;
  readingTime?: number;
  tags: string[];
}

interface Props {
  posts: PostPreview[];
  featuredPost?: PostPreview;
  categories?: {
    slug: string;
    label: string;
    description: string;
  }[];
}

const { posts, featuredPost, categories = [] } = Astro.props;

const categoryLabels = {
  'money-basics': '돈 관리 기초',
  'life-stages': '상황별 가이드',
  'saving-tips': '절약 실전',
  'app-guides': '앱 사용 가이드',
} as const;
---

<section class="relative overflow-hidden bg-[linear-gradient(to_bottom,_#fffdf8,_#ffffff)] py-24 sm:py-28">
  <div class="absolute inset-0 -z-10 opacity-70" aria-hidden="true">
    <div class="absolute left-1/2 top-0 h-72 w-72 -translate-x-1/2 rounded-full bg-secondary/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-primary/10 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <span class="text-sm font-bold uppercase tracking-widest text-primary">콘텐츠</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-base-content sm:text-4xl lg:text-[2.75rem]">
          쓰는 법부터 비교 글까지<br />바로 읽을 수 있게 정리했습니다.
        </h2>
        <p class="mt-4 text-lg text-base-content/60">
          가계부를 처음 시작하는 사람도, 어떤 앱을 써야 할지 고민하는 사람도 바로 도움이 되는 글만 모았습니다.
        </p>
      </div>

      <a
        href="/blog"
        data-track-event="home_blog_index_click"
        data-track-source="home_preview"
        class="inline-flex items-center gap-2 self-start rounded-full border border-base-300 bg-white px-5 py-3 text-sm font-semibold text-base-content transition hover:-translate-y-0.5 hover:border-primary/20 hover:text-primary hover:shadow-lg"
      >
        블로그 전체 보기
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    {categories.length > 0 && (
      <div class="mt-8 grid gap-3 lg:grid-cols-3">
        {categories.map((category) => (
          <a
            href={`/blog?category=${category.slug}`}
            data-track-event="home_blog_category_click"
            data-track-source="home_preview"
            data-track-category={category.slug}
            class="rounded-[22px] border border-base-300 bg-white/85 px-5 py-4 transition hover:-translate-y-0.5 hover:border-primary/20 hover:bg-white hover:shadow-lg"
          >
            <div class="text-sm font-black text-base-content">{category.label}</div>
            <p class="mt-2 text-sm leading-6 text-base-content/65">{category.description}</p>
          </a>
        ))}
      </div>
    )}

    {featuredPost && (
      <a
        href={`/blog/${featuredPost.slug}/`}
        data-track-event="home_blog_featured_click"
        data-track-source="home_preview"
        data-track-slug={featuredPost.slug}
        class="mt-8 block overflow-hidden rounded-[32px] border border-primary/10 bg-[linear-gradient(135deg,_rgba(37,99,235,0.08),_rgba(255,255,255,0.98))] p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl sm:p-8"
      >
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-base-content/50">
          <span class="rounded-full bg-primary px-3 py-1 text-primary-content">추천 글</span>
          <span class="rounded-full bg-white/80 px-3 py-1 text-primary">
            {categoryLabels[featuredPost.category]}
          </span>
          <span>{featuredPost.publishDate.toLocaleDateString('ko-KR')}</span>
          <span>{featuredPost.readingTime ?? 5}분 읽기</span>
        </div>
        <h3 class="mt-4 max-w-3xl text-3xl font-black leading-tight text-base-content sm:text-4xl">
          {featuredPost.title}
        </h3>
        <p class="mt-4 max-w-3xl text-base leading-8 text-base-content/72">
          {featuredPost.excerpt || featuredPost.description}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {featuredPost.tags.slice(0, 4).map((tag) => (
            <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-medium text-base-content/70">
              #{tag}
            </span>
          ))}
        </div>
      </a>
    )}

    <div class="mt-14 grid gap-5 lg:grid-cols-3">
      {posts.map((post, index) => (
        <a
          href={`/blog/${post.slug}/`}
          data-track-event="home_blog_card_click"
          data-track-source="home_preview"
          data-track-slug={post.slug}
          class="group reveal rounded-[28px] border border-base-300 bg-white p-7 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-primary/20 hover:shadow-xl"
          style={`animation-delay: ${index * 120}ms;`}
        >
          <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-base-content/50">
            <span class="rounded-full bg-primary/10 px-3 py-1 text-primary">
              {categoryLabels[post.category]}
            </span>
            <span>{post.publishDate.toLocaleDateString('ko-KR')}</span>
            <span>{post.readingTime ?? 5}분 읽기</span>
          </div>

          <h3 class="mt-4 text-2xl font-black leading-tight text-base-content transition group-hover:text-primary">
            {post.title}
          </h3>
          <p class="mt-4 text-sm leading-7 text-base-content/72">
            {post.excerpt || post.description}
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            {post.tags.slice(0, 3).map((tag) => (
              <span class="rounded-full bg-base-200 px-3 py-1 text-xs font-medium text-base-content/65">
                #{tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
